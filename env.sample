# MIYA — nusxa oling: cp env.sample .env  va qiymatlarni to‘ldiring

# ── Umumiy ─────────────────────────────────────────────────────────────
MIYA_ENV=development
MIYA_DEBUG=false
MIYA_LOG_LEVEL=INFO
MIYA_SECRET_KEY=change-me-to-long-random
MIYA_DATA_DIR=

# ── API ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:7860,http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-long-random
JWT_EXPIRE_MINUTES=1440

# ── GPU / modellar (nomlar backend/models/ dagi fayllarga mos) ─────────
CUDA_VISIBLE_DEVICES=0
GPU_LAYERS=35
# ORCHESTRATOR_MODEL=...
# CHAT_MODEL=...

# ── Tashqi servislar (Docker nomlari) ───────────────────────────────────
REDIS_HOST=redis
CHROMA_HOST=chroma
SEARXNG_HOST=http://searxng:8080

# ── Xavfsizlik: productionda host_shell ────────────────────────────────
# MIYA_ALLOW_HOST_SHELL=1

# ── Voice STT (frontend/voice) ─────────────────────────────────────────
# MIYA_STT_DEVICE=cpu
# MIYA_STT_ALLOW_GPU=1
# MIYA_STT_MODEL=base
